APP_NAME=Kenfinly
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

JWT_SECRET=

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kenfinly
DB_USERNAME=kenfinly
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
# WordPress Configuration (Optional - for content features)
WORDPRESS_API_URL=
WORDPRESS_USERNAME=
WORDPRESS_APPLICATION_PASSWORD=
WORDPRESS_TIMEOUT=
WORDPRESS_RETRIES=
WORDPRESS_CUSTOM_POST_TYPES=

COMPANY_NAME=
COMPANY_TAX_CODE=
COMPANY_EMAIL=
COMPANY_PHONE=
COMPANY_ADDRESS=

VITE_PROFILE_TWITTER=
VITE_PROFILE_FACEBOOK=
VITE_PROFILE_LINKEDIN=

GA4_ENABLED=
VITE_SUBSCRIPTIONS_ENABLED=true
APP_TIMEZONE=Asia/Ho_Chi_Minh

SITEMAP_GENERATION_FREQUENCY=daily
GOOGLE_ANALYTICS_PROPERTY_ID=your-property-id
GOOGLE_ANALYTICS_CREDENTIALS_PATH=/path/to/service-account-key.json
TRAFFIC_STATS_ENABLED=false
COOKIE_CONSENT_ENABLED=false
STAGING_ACCESS_CODE=your_secure_beta_code_here


# ── WooCommerce Webhook ───────────────────────────────────────────────────
# Shared secret configured on the WooCommerce → Webhooks settings page.
# Must match the secret used when creating the webhook delivery in WooCommerce.
# Used by VerifyWooCommerceSignature middleware to validate X-WC-Webhook-Signature.
WOOCOMMERCE_WEBHOOK_SECRET=your_woocommerce_webhook_secret_here

# ── PayOS Payment Gateway ─────────────────────────────────────────────────
PAYOS_CLIENT_ID=your_payos_client_id_here
PAYOS_API_KEY=your_payos_api_key_here
PAYOS_CHECKSUM_KEY=your_payos_checksum_key_here

# Plan pricing in VND (integers)
PAYOS_MONTHLY_AMOUNT=79000
PAYOS_YEARLY_AMOUNT=169000
PAYOS_MONTHLY_DESC=KenFinly Monthly Pro
PAYOS_YEARLY_DESC=KenFinly Yearly Pro

# PayOS redirect URLs (defaults to APP_URL/pricing?payment=...)
# PAYOS_RETURN_URL=https://your-domain.com/pricing?payment=success
# PAYOS_CANCEL_URL=https://your-domain.com/pricing?payment=cancelled
