#!/usr/bin/env bash
set -euo pipefail

remote_name="${1:-origin}"
protected_branch="staging"

while read -r _local_ref _local_sha remote_ref _remote_sha; do
  if [[ "$remote_name" == "origin" && "$remote_ref" == "refs/heads/${protected_branch}" ]]; then
    cat <<MSG

Heads up: this push updates '${protected_branch}' and should trigger Jenkins.
For automatic terminal log streaming, use:

  git push-staging

Git itself has no post-push hook, so this pre-push hook cannot wait for Jenkins
after the push completes. The local git alias handles that workflow.

MSG
  fi
done
