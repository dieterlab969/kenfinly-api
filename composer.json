{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "repositories": [
        {
            "type": "composer",
            "url": "https://wpackagist.org"
        }
    ],
    "require": {
        "php": "^8.2",
        "google/analytics-data": "^0.23.1",
        "intervention/image": "^3.11",
        "intervention/image-laravel": "^1.5",
        "johnpbloch/wordpress": "^6.7",
        "laravel/framework": "^12.0",
        "laravel/tinker": "^2.10.1",
        "spatie/laravel-sitemap": "^7.3",
        "tymon/jwt-auth": "^2.2",
        "wpackagist-plugin/jwt-authentication-for-wp-rest-api": "^1.4"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "bash ./scripts/composer.sh install",
            "bash ./scripts/php.sh -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "bash ./scripts/php.sh artisan key:generate",
            "bash ./scripts/php.sh artisan migrate --force",
            "bash ./scripts/ensure-storage-link.sh",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "sh -c 'REQUESTED_APP_PORT=${APP_PORT:-5000}; APP_HOST=${APP_HOST:-0.0.0.0}; APP_PORT=$(bash ./scripts/find-open-port.sh \"$REQUESTED_APP_PORT\" \"$APP_HOST\"); if [ \"$APP_PORT\" != \"$REQUESTED_APP_PORT\" ]; then echo \"Port $REQUESTED_APP_PORT is already in use. Falling back to $APP_PORT for Laravel.\"; fi; bash ./scripts/ensure-storage-link.sh && npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"env PHP_CLI_SERVER_WORKERS=1 bash ./scripts/php.sh artisan serve --host=$APP_HOST --port=$APP_PORT\" \"bash ./scripts/php.sh artisan queue:listen --tries=1\" \"bash ./scripts/php.sh artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others'"
        ],
        "test": [
            "bash ./scripts/php.sh artisan config:clear --ansi",
            "bash ./scripts/php.sh artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "bash ./scripts/php.sh artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "bash ./scripts/php.sh artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "bash ./scripts/php.sh -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "bash ./scripts/php.sh artisan key:generate --ansi",
            "bash ./scripts/php.sh -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "bash ./scripts/php.sh artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        },
        "wordpress-install-dir": "public/wordpress",
        "installer-paths": {
            "public/wordpress/wp-content/plugins/{$name}/": ["type:wordpress-plugin"],
            "public/wordpress/wp-content/themes/{$name}/": ["type:wordpress-theme"]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "johnpbloch/wordpress-core-installer": true,
            "composer/installers": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
